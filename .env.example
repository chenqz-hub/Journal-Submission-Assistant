# ==============================
# LLM Configuration (Choose One)
# ==============================

# Option 1: OpenAI (Official)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Option 2: DeepSeek (深度求索) - Recommended for cost/performance
# Register: https://platform.deepseek.com/
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# Option 3: Moonshot / Kimi (月之暗面)
# Register: https://platform.moonshot.cn/
# OPENAI_API_KEY=sk-your-moonshot-key
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# Option 4: Zhipu AI / GLM (智谱清言)
# Register: https://open.bigmodel.cn/
# OPENAI_API_KEY=your-zhipu-api-key
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-4-flash

# Option 5: Local Ollama (Free, runs locally)
# Install: https://ollama.com/
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3:8b
# ==============================
# Security Configuration
# ==============================
# Set a secret code here to prevent unauthorized access. If empty, no code is needed.
ACCESS_CODE=sciauto123

